{
  "henrikkarlsson.xyz": {
    "title_selector": "h1.post-title",
    "subtitle_selector": "h3.subtitle",
    "body_selector": "div.available-content > div.body.markup",
    "remove_selectors": [
      ".subscription-widget-wrap",
      "div.share-dialog",
      "button"
    ],
    "source_position": "bottom",
    "title_align": "left",
    "subtitle_align": "left",
    "show_separator": false,
    "custom_css_path": "css/karlsson.css",
    "transformations": [
      {
        "target_selector": "div[data-component-name='DigestPostEmbed']",
        "extractors": {
          "Url": { "selector": "a", "attr": "href" },
          "Title": { "selector": "h4", "attr": "text" },
          "Author": { "selector": "a[href*='/profile/']", "attr": "text" },
          "Date": { 
            "selector": "", 
            "attr": "text", 
            "regex": "([A-Z][a-z]+\\s\\d{1,2},\\s\\d{4})" 
          }
        },
        "replacement_html": "<ul style=\"margin: 5px 0; padding-left: 20px;\"><li style=\"margin-bottom: 5px;\"><strong><a href=\"{Url}\" style=\"color: #0056b3; text-decoration: none; border-bottom: 1px dotted #0056b3;\">{Title}</a></strong> - {Author} | {Date}</li></ul>"
      },
      {
        "target_selector": "a.footnote-number",
        "extractors": {
          "Number": { "selector": "", "attr": "text" }
        },
        "replacement_html": "<p class=\"footnote-number\">{Number}</p>"
      },
      {
        "target_selector": ".captioned-image-container:has(+ .captioned-image-container)",
        "extractors": {
          "Content": { "selector": "", "attr": "html" }
        },
        "replacement_html": "<div style=\"display: flex; gap: 10px; justify-content: center; width: 100%; clear: both; margin: 20px 0;\">{Content}</div>"
      }
    ]
  }
}
