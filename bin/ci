#!/usr/bin/env bash
set -euo pipefail

echo "==> gofmt"
unformatted="$(gofmt -l .)"
if [[ -n "$unformatted" ]]; then
  printf '%s\n' "$unformatted"
  echo "Run: gofmt -w ." >&2
  exit 1
fi

echo "==> go vet"
go vet ./...

echo "==> golangci-lint"
golangci-lint run

echo "==> tests"
go test -race ./...

echo "==> govulncheck"
govulncheck ./...

# anti-slop gate: em-dash in prose + the tool-name leak. Canonical: llm-workflow bin/slop-guard.
echo "==> slop-guard"; bin/slop-guard --diff "${SLOP_GUARD_BASE:-origin/main}"

echo "CI green."
